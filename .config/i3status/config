# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
	colors = true
        interval = 5
	color_good = "#a9b665"     # Gruvbox Material Green
        color_degraded = "#d8a657" # Gruvbox Material Yellow/Orange
        color_bad = "#ea6962"      # Gruvbox Material Red
}

# Define which modules to load and in what order
order += "disk /"
order += "cpu_usage"
order += "memory"
order += "volume master"
order += "ethernet _first_"
order += "tztime local"

# Module Configurations
disk "/" {
        format = " HDD: %avail "
}

cpu_usage {
        format = " CPU: %usage "
}

memory {
        format = " RAM: %used "
        threshold_degraded = "10%"
}

ethernet _first_ {
        # Only shows IP if connected. Drops the unnecessary speed metrics.
        format_up = " ETH"
        format_down = " ETH: down "
}

tztime local {
       # Formats time to 12-hour: YYYY-MM-DD HH:MM AM/PM
        format = " %Y-%m-%d %I:%M %p "
}

volume master {
        format = "♪: %volume"
        format_muted = "♪: muted (%volume)"
        device = "default"
}
